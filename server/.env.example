# ── Core ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/smartquiz_ai

# ── Authentication ────────────────────────────────────────────────────────────
# Generate: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=replace_with_a_64_byte_secure_random_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=7
CSRF_SECRET=replace_with_another_64_byte_secure_random_string

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
# CLIENT_ORIGINS=http://localhost:5173,https://yourdomain.com  (comma-separated list)

# ── Trust Proxy (set true on Render, Heroku, Nginx) ──────────────────────────
TRUST_PROXY=false

# ── AI Provider Layer ─────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=30000

# Get your key at https://aistudio.google.com
GEMINI_API_KEY=

AI_PRIMARY_PROVIDER=openrouter
AI_FALLBACK_PROVIDER=gemini

# ── Caching ───────────────────────────────────────────────────────────────────
CACHE_TTL=1800
CACHE_PROVIDER=memory
